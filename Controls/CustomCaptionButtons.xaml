<UserControl
    x:Class="WinUINav.Controls.CustomCaptionButtons"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid"
          Width="138"
          Height="48"
          MinWidth="138"
          Background="Transparent"
          HorizontalAlignment="Right"
          VerticalAlignment="Stretch"
          UseLayoutRounding="True"
          PointerExited="RootGrid_PointerExited">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="46"/>
            <ColumnDefinition Width="46"/>
            <ColumnDefinition Width="46"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="MinButtonHost"
                Grid.Column="0"
                Background="Transparent"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ToolTipService.ToolTip="最小化"
                PointerEntered="MinButtonHost_PointerEntered"
                PointerExited="MinButtonHost_PointerExited"
                PointerMoved="MinButtonHost_PointerMoved"
                PointerPressed="MinButtonHost_PointerPressed"
                PointerReleased="MinButtonHost_PointerReleased"
                PointerCanceled="MinButtonHost_PointerCanceled"
                PointerCaptureLost="MinButtonHost_PointerCaptureLost">
            <Viewbox Width="10"
                     Height="10"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     IsHitTestVisible="False">
                <TextBlock x:Name="MinGlyph"
                           Text="&#xE921;"
                           FontFamily="{ThemeResource SymbolThemeFontFamily}"
                           IsHitTestVisible="False"/>
            </Viewbox>
        </Border>

        <Border x:Name="MaxButtonHost"
                Grid.Column="1"
                Background="Transparent"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ToolTipService.ToolTip="最大化"
                IsHitTestVisible="False">
            <Viewbox Width="10"
                     Height="10"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     IsHitTestVisible="False">
                <TextBlock x:Name="MaxGlyph"
                           Text="&#xE922;"
                           FontFamily="{ThemeResource SymbolThemeFontFamily}"
                           IsHitTestVisible="False"/>
            </Viewbox>
        </Border>

        <Border x:Name="CloseButtonHost"
                Grid.Column="2"
                Background="Transparent"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ToolTipService.ToolTip="关闭"
                PointerEntered="CloseButtonHost_PointerEntered"
                PointerExited="CloseButtonHost_PointerExited"
                PointerMoved="CloseButtonHost_PointerMoved"
                PointerPressed="CloseButtonHost_PointerPressed"
                PointerReleased="CloseButtonHost_PointerReleased"
                PointerCanceled="CloseButtonHost_PointerCanceled"
                PointerCaptureLost="CloseButtonHost_PointerCaptureLost">
            <Viewbox Width="10"
                     Height="10"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     IsHitTestVisible="False">
                <TextBlock x:Name="CloseGlyph"
                           Text="&#xE8BB;"
                           FontFamily="{ThemeResource SymbolThemeFontFamily}"
                           IsHitTestVisible="False"/>
            </Viewbox>
        </Border>
    </Grid>
</UserControl>