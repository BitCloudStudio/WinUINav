<Page
    x:Class="WinUINav.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="Transparent" Padding="32">
            <StackPanel Spacing="16">

                <StackPanel Spacing="6">
                    <TextBlock Text="关于"
                           FontSize="28"
                           Padding="0,0,0,8"
                           FontWeight="SemiBold" />
                    <TextBlock Text="关于本产品"
                               Opacity="0.72"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Border
                    Padding="18"
                    CornerRadius="4"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Width="72" Height="72">
                            <Image Source="ms-appx:///Assets/StoreLogo.scale-200.png"
                                   Width="52"
                                   Height="52"
                                   Stretch="Uniform"          
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Grid>

                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="WinUINav Demo"
                                       FontSize="22"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="版本 1.0.0.0"
                                       Opacity="0.78" />
                            <TextBlock Text="Template for WinUI3"
                                       TextWrapping="WrapWholeWords"
                                       Opacity="0.72" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Padding="18"
                    CornerRadius="8"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="开发者"
                                   FontSize="18"
                                   FontWeight="SemiBold" />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Padding="14"
                                    CornerRadius="6"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="BitChen"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="程序设计/组件设计"
                                               Opacity="0.7" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Padding="14"
                                    CornerRadius="6"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="MIT"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="开源协议"
                                               Opacity="0.7" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Padding="18"
                    CornerRadius="8"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="官网"
                                   FontSize="18"
                                   FontWeight="SemiBold" />

                        <Border
                            Padding="14"
                            CornerRadius="6"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="查看我们的GitHub主页"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="您可以在这里获取帮助与支持"
                                               Opacity="0.72" />
                                </StackPanel>

                                <HyperlinkButton Grid.Column="1"
                                                 Content="跳转"
                                                 NavigateUri="https://github.com/BitCloudStudio/WinUINav"
                                                 VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border
                    Padding="14"
                    CornerRadius="6"
                    Background="#0F7A7A7A"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <TextBlock Text="感谢您使用 WinUINav"
                               Opacity="0.75"
                               TextWrapping="WrapWholeWords" />
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>