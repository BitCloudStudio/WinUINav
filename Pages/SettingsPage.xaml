<Page
    x:Class="WinUINav.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent" Padding="32">
        <StackPanel Spacing="12">
            <TextBlock Text="设置"
                       FontSize="26"
                       FontWeight="SemiBold"/>

            <Expander
                IsExpanded="True"
                ExpandDirection="Down"
                VerticalAlignment="Top"
                Header="布局设置"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="导航栏位置"
                               VerticalAlignment="Center"/>

                    <ComboBox x:Name="NavModeComboBox"
                              Grid.Column="1"
                              Width="150"
                              SelectionChanged="NavModeComboBox_SelectionChanged"
                              Loaded="NavModeComboBox_Loaded">
                        <ComboBoxItem Content="左侧 (Left)" Tag="Left"/>
                        <ComboBoxItem Content="顶部 (Top)" Tag="Top"/>
                        <ComboBoxItem Content="自动 (Auto)" Tag="Auto"/>
                    </ComboBox>
                </Grid>
            </Expander>

            <Expander
                IsExpanded="True"
                ExpandDirection="Down"
                VerticalAlignment="Top"
                Header="窗口材质"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="窗口背景材质"
                               VerticalAlignment="Center"/>

                    <ComboBox x:Name="BackdropModeComboBox"
                              Grid.Column="1"
                              Width="180"
                              Loaded="BackdropModeComboBox_Loaded"
                              SelectionChanged="BackdropModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="云母 (Mica)" Tag="Mica"/>
                        <ComboBoxItem Content="高透云母 (Mica Alt)" Tag="MicaAlt"/>
                        <ComboBoxItem Content="亚克力 (Acrylic)" Tag="Acrylic"/>
                    </ComboBox>
                </Grid>
            </Expander>

            <Expander
                IsExpanded="True"
                ExpandDirection="Down"
                VerticalAlignment="Top"
                Header="程序主题"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="程序主题"
                   VerticalAlignment="Center"/>

                    <ComboBox x:Name="ThemeComboBox"
                  Grid.Column="1"
                  Width="180"
                  Loaded="ThemeComboBox_Loaded"
                  SelectionChanged="ThemeComboBox_SelectionChanged">
                        <ComboBoxItem Content="跟随系统" Tag="Default"/>
                        <ComboBoxItem Content="浅色" Tag="Light"/>
                        <ComboBoxItem Content="深色" Tag="Dark"/>
                    </ComboBox>
                </Grid>
            </Expander>
        </StackPanel>
    </Grid>
</Page>