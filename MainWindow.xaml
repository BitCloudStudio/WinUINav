<Window
    x:Class="WinUINav.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUINav.Controls"
    mc:Ignorable="d"
    Title="WinUINav">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.Resources>
            <Thickness x:Key="NavigationViewContentMargin">0,48,0,0</Thickness>
            <Thickness x:Key="NavigationViewHeaderMargin">56,34,0,0</Thickness>
            <Thickness x:Key="NavigationViewPageContentMargin">0,0,0,0</Thickness>
            <CornerRadius x:Key="NavigationViewContentGridCornerRadius">8,0,0,0</CornerRadius>
            <Thickness x:Key="NavigationViewContentGridBorderThickness">1,1,0,0</Thickness>
        </Grid.Resources>

        <NavigationView x:Name="RootNavView"
                    IsBackButtonVisible="Visible"
                    IsTitleBarAutoPaddingEnabled="False"
                    IsPaneToggleButtonVisible="True"
                    PaneDisplayMode="Auto"
                    Loaded="RootNavView_Loaded"
                    BackRequested="RootNavView_BackRequested"
                    DisplayModeChanged="RootNavView_DisplayModeChanged"
                    SelectionChanged="RootNavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="首页" Tag="home">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="文件" Tag="files">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Folder"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="关于" Tag="about">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Help"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid Margin="{StaticResource NavigationViewPageContentMargin}">
                <Frame x:Name="ContentFrame" Navigated="ContentFrame_Navigated"/>
            </Grid>
        </NavigationView>

        <Grid x:Name="AppTitleBar"
          Canvas.ZIndex="1"
          Height="{Binding ElementName=RootNavView, Path=CompactPaneLength}"
          VerticalAlignment="Top"
          IsHitTestVisible="True">

            <Grid Background="Transparent">
                <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,0,0">
                    <Image Source="/Assets/Square44x44Logo.png"
                       Width="24"
                       Height="24"
                       VerticalAlignment="Center"
                       Stretch="Uniform"/>

                    <TextBlock x:Name="TitleText"
                           Text="WinUINav"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Opacity="0.75"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <controls:CustomCaptionButtons x:Name="CaptionButtons"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Stretch"/>
            </Grid>
        </Grid>
    </Grid>
</Window>